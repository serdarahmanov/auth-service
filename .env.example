# ----------------------------
# Database
# ----------------------------
DB_URL=jdbc:postgresql://localhost:5432/wavy
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2
DB_IDLE_TIMEOUT_MS=30000
DB_MAX_LIFETIME_MS=180000
DB_CONNECTION_TIMEOUT_MS=20000

# ----------------------------
# Mail
# ----------------------------
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=your_mail_user
MAIL_PASSWORD=your_mail_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=false

# ----------------------------
# Google OAuth2 client
# ----------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ----------------------------
# App URLs
# ----------------------------
APP_BASE_URL=http://localhost:8080
APP_NAME=Wavy
APP_LOGIN_PAGE_URL=http://localhost:3000/auth/login
APP_FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/auth/reset-password
# Optional override; usually derived from APP_BASE_URL.
# APP_RESET_PASSWORD_URL=http://localhost:8080/api/auth/forgot-password
# APP_LOGIN_SUCCESS_URL=http://localhost:8080/auth/login-success

# ----------------------------
# JWT
# Use issuer + kid for JWT metadata.
# Provide PEM keypair for stable signatures across restarts.
# If PEM keys are not provided, app generates a dev keypair at startup.
# ----------------------------
JWT_ISSUER=music-app-backend
JWT_KEY_ID=dev-rsa-key-1
JWT_RSA_PRIVATE_KEY_PEM=
JWT_RSA_PUBLIC_KEY_PEM=
JWT_ALLOW_EPHEMERAL_KEYS=true
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=1209600000

# ----------------------------
# S3 / Object Storage
# ----------------------------
S3_BUCKET_NAME=music-app-public-dev
S3_REGION=us-east-1
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_BASE_URL=http://localhost:4566/dummy-bucket-local
S3_STORAGE_CLASS=STANDARD

# ----------------------------
# Internal OAuth2 code flow settings
# ----------------------------
APP_OAUTH2_AUTH_CODE_TTL_SECONDS=3600
APP_OAUTH2_CLEANUP_INTERVAL_MS=3600000
APP_OAUTH2_CLEANUP_INITIAL_DELAY_MS=60000

# ----------------------------
# Optional logging / dashboard
# ----------------------------
SPRING_SECURITY_LOG_LEVEL=INFO
JOBRUNR_DASHBOARD_ENABLED=false
JOBRUNR_DASHBOARD_PORT=8000

# ----------------------------
# CORS
# Comma-separated origins (for prod with `SPRING_PROFILES_ACTIVE=prod`, this must be set).
# ----------------------------
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
